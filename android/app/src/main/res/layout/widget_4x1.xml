<?xml version="1.0" encoding="utf-8"?>
<!--
    Melody Flow 4x1 home-screen widget.
    Layout: [artwork 72dp] [title / artist] [prev] [play/pause] [next]

    This is RemoteViews-compatible only. Do NOT use ConstraintLayout, fancy
    backgrounds, or custom views here — RemoteViews supports a strict subset
    of Android widgets. Referenced drawables:
      - widget_bg.xml           (rounded dark container)
      - widget_btn_bg.xml       (subtle circular bg on control buttons)
      - ic_music_fallback.xml   (when no artwork is available)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="8dp"
    android:background="@drawable/widget_bg">

    <!-- Artwork — tapping opens the app -->
    <ImageView
        android:id="@+id/widget_artwork"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_music_fallback"
        android:contentDescription="Album art"
        android:background="@drawable/widget_artwork_bg"
        android:layout_marginEnd="10dp" />

    <!-- Title + artist stack — this area also opens the app when tapped -->
    <LinearLayout
        android:id="@+id/widget_info_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="4dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Melody Flow"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap to start playing"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Previous button -->
    <ImageButton
        android:id="@+id/widget_prev"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_media_previous"
        android:background="@drawable/widget_btn_bg"
        android:contentDescription="Previous"
        android:scaleType="centerInside"
        android:tint="#FFFFFFFF" />

    <!-- Play/pause — larger, central -->
    <ImageButton
        android:id="@+id/widget_play_pause"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_media_play"
        android:background="@drawable/widget_btn_bg_accent"
        android:contentDescription="Play or pause"
        android:scaleType="centerInside"
        android:layout_marginHorizontal="4dp"
        android:tint="#FFFFFFFF" />

    <!-- Next button -->
    <ImageButton
        android:id="@+id/widget_next"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_media_next"
        android:background="@drawable/widget_btn_bg"
        android:contentDescription="Next"
        android:scaleType="centerInside"
        android:tint="#FFFFFFFF" />

</LinearLayout>
